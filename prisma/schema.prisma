
generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Expense {
  id                    Int     @id   @default(autoincrement())
  description           String 
  amount                Float
  category              String
  createdAt             DateTime  @default(now())
  updatedAt             DateTime   @updatedAt 
  userId                String
}